# Environment variables for Neural Data Wallets

# Deploy your contract to Base Sepolia
# Get RPC URL from: https://base.org/developers
# Get testnet ETH from: https://cloud.google.com/base-faucet

# For Base Sepolia testnet:
NEXT_PUBLIC_CHAIN_ID="84532"
RPC_URL="https://sepolia.base.org"

# Your wallet private key (DO NOT COMMIT THIS)
PRIVATE_KEY=""

# Pinata IPFS credentials (get from https://pinata.cloud)
PINATA_JWT=""
PINATA_GATEWAY="https://gateway.pinata.cloud"
